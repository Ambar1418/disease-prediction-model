{
  "version": 2,
  "builds": [
    {
      "src": "minor/api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "250mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "minor/api/index.py"
    }
  ],
  "functions": {
    "minor/api/index.py": {
      "runtime": "python3.12"
    }
  }
}
