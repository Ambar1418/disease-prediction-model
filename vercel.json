{
  "version": 2,
  "builds": [
    {
      "src": "minor/core/wsgi.py",
      "use": "@vercel/python",
      "config": { 
        "maxLambdaSize": "50mb",
        "python": {
          "runtime": "python3.9"
        }
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/minor/core/wsgi.py"
    }
  ]
}
