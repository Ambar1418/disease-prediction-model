{
  "version": 2,
  "builds": [
    {
      "src": "**/*.py",
      "use": "@vercel/python",
      "config": { 
        "maxLambdaSize": "50mb",
        "python": {
          "runtime": "python3.11"
        }
      }
    }
  ],
  "routes": [
    {
      "src": "^/static/(.*)",
      "dest": "/minor/staticfiles/$1"
    },
    {
      "src": "^/(.*)",
      "dest": "/minor/manage.py"
    }
  ],
  "env": {
    "PYTHONPATH": "/var/task/minor",
    "DJANGO_SETTINGS_MODULE": "core.settings",
    "PYTHONUNBUFFERED": "1"
  }
}
