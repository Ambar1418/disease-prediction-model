{
  "version": 2,
  "builds": [
    {
      "src": "minor/api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "250mb",
        "python": "3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "minor/api/index.py"
    }
  ],
  "env": {
    "PIP_NO_CACHE_DIR": "1",
    "PIP_DISABLE_PIP_VERSION_CHECK": "1",
    "VERCEL": "1",
    "PYTHON_VERSION": "3.11"
  }
}
